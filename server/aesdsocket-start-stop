#!/bin/sh

case "$1" in
    start)
        echo "Loading aesdchar..."
        modprobe aesdchar || exit 1
        [ -e /dev/aesdchar ] && chmod 666 /dev/aesdchar
        echo "Starting aesdsocket..."
        /usr/bin/aesdsocket -d
        ;;
    stop)
        echo "Stopping aesdsocket..."
        killall aesdsocket 2>/dev/null
        echo "Unloading aesdchar..."
        rmmod aesdchar 2>/dev/null
        ;;
    restart)
        $0 stop
        $0 start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
